function Tackle({ lures, setLures, coords, requestLocation }) {
  const [mode, setMode] = useState(null); // null | 'manual'
  const [desc, setDesc] = useState("");
  const [toast, setToast] = useState("");
  const [gtab, setGtab] = useState("box"); // box | guide

  const scan = () => {
    const c = CATALOG[Math.floor(Math.random() * CATALOG.length)];
    setLures((p) => [{ id: uid(), ...c, image: null, manual: false }, ...p]);
    setToast(`Scanned: ${c.name}`);
    setTimeout(() => setToast(""), 1800);
  };

  const saveManual = () => {
    if (!desc.trim()) return;
    setLures((p) => [{
      id: uid(), name: desc.trim(), color: "—", brightness: "natural", shape: "custom",
      source: "Manual entry", body: "#2a3240", accent: "#3a4452", image: null, manual: true,
    }, ...p]);
    setDesc(""); setMode(null);
    setToast("Saved to your tackle box");
    setTimeout(() => setToast(""), 2200);
  };

  const setPhoto = (id, dataUri) =>
    setLures((p) => p.map((l) => (l.id === id ? { ...l, image: dataUri } : l)));

  return (
    <Scroll>
      <div style={styles.segment}>
        <button style={{ ...styles.segBtn, ...(gtab === "box" ? styles.segOn : {}) }} onClick={() => setGtab("box")}>Tackle Box</button>
        <button style={{ ...styles.segBtn, ...(gtab === "guide" ? styles.segOn : {}) }} onClick={() => setGtab("guide")}>Fish Library</button>
        <button style={{ ...styles.segBtn, ...(gtab === "cook" ? styles.segOn : {}) }} onClick={() => setGtab("cook")}>Cooking</button>
      </div>

      {gtab === "guide" ? <FishGuide coords={coords} requestLocation={requestLocation} />
        : gtab === "cook" ? <Cooking />
        : (
        <>
          <div style={styles.scanRow}>
            <button style={styles.scanBtn} onClick={scan}>
              <Barcode size={20} /> Scan barcode
            </button>
            <button style={styles.dropBtn} onClick={() => setMode(mode === "manual" ? null : "manual")}>
              <ChevronDown size={16} style={{ transform: mode === "manual" ? "rotate(180deg)" : "none", transition: ".2s" }} />
            </button>
          </div>

          {mode === "manual" && (
            <div style={styles.manualCard}>
              <textarea value={desc} onChange={(e) => setDesc(e.target.value)} rows={2}
                placeholder="Describe the lure (e.g. '3in white paddle-tail swimbait')"
                style={styles.textarea} />
              <button style={styles.primaryBtn} onClick={saveManual}>Save description</button>
            </div>
          )}

          {toast && <div style={styles.toast}>{toast}</div>}

          <div style={styles.grid}>
            {lures.map((l) => <LureCard key={l.id} lure={l} onPhoto={setPhoto} />)}
          </div>
        </>
      )}
    </Scroll>
  );
}

function LureCard({ lure, onPhoto }) {
  const fileRef = useRef(null);
  const pick = (e) => {
    const f = e.target.files?.[0];
    if (!f) return;
    const r = new FileReader();
    r.onload = () => onPhoto(lure.id, r.result);
    r.readAsDataURL(f);
  };
  // manual lure with no photo yet -> white box + camera icon
  const whiteBox = lure.manual && !lure.image;
  return (
    <div style={styles.card}>
      <div style={styles.cardImg}>
        {lure.image ? (
          <img src={lure.image} alt={lure.name} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
        ) : whiteBox ? (
          <div style={styles.whiteBox}>
            <button style={styles.camBtn} onClick={() => fileRef.current?.click()} aria-label="Take photo">
              <Camera size={16} color="#1a1a1a" />
            </button>
          </div>
        ) : (
          <LureArt body={lure.body} accent={lure.accent} size={72} />
        )}
        {!whiteBox && (
          <button style={styles.camBtnDark} onClick={() => fileRef.current?.click()} aria-label="Replace photo">
            <Camera size={14} color="#fff" />
          </button>
        )}
      </div>
      <div style={{ padding: "8px 10px" }}>
        <div style={{ fontWeight: 700, fontSize: 13, lineHeight: 1.2 }}>{lure.name}</div>
        <div style={styles.lbSub}>{lure.color}{lure.color !== "—" ? " · " : ""}{lure.shape}</div>
        <div style={styles.srcChip}>{lure.source}</div>
      </div>
      <input ref={fileRef} type="file" accept="image/*" capture="environment" onChange={pick} style={{ display: "none" }} />
    </div>
  );
}

