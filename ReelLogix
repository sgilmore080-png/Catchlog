  const [view, setView] = useState("friends");   // friends | chats
  const [openConv, setOpenConv] = useState(null); // listing id
  const [ltab, setLtab] = useState("lobby");      // lobby | rules

  const conversations = (listings || []).filter((l) => l.messages && l.messages.length > 0);
  const current = conversations.find((c) => c.id === openConv);

  const addFriend = () => {
    const v = addId.trim();
    if (!/^#?\d{3,4}$/.test(v)) return;
    const id = v.startsWith("#") ? v : "#" + v;
    if (friends.some((f) => f.id === id)) return;
    setFriends((p) => [...p, { id, name: "Angler " + id }]);
    setAddId("");
  };

  const makeCode = () => "RLX-" + Math.random().toString(36).slice(2, 6).toUpperCase();
  const newPlayer = (id, name, you) => ({ id, name, you: !!you, log: [] });

  const startTourney = () => {
    setTourney({ code: makeCode(), status: "lobby", hostId: myId, rules: { ...DEFAULT_RULES }, players: [newPlayer(myId, "You", true)] });
  };
  const inviteToTourney = (f) => {
    setTourney((t) => t.players.some((p) => p.id === f.id) ? t : { ...t, players: [...t.players, newPlayer(f.id, f.name, false)] });
  };
  const setRule = (key, val) => setTourney((t) => ({ ...t, rules: { ...t.rules, [key]: val } }));
  const beginTourney = () => { setTourney((t) => ({ ...t, status: "running" })); goHome(); };
  const cancelTourney = () => setTourney(null);

  const join = () => {
    if (!joinCode.trim()) return;
    setTourney({ code: joinCode.trim().toUpperCase(), status: "running", hostId: "host", rules: { ...DEFAULT_RULES }, players: [newPlayer(myId, "You", true)] });
    setJoinOpen(false); setJoinCode("");
    goHome();
  };

  const copyId = () => { navigator.clipboard?.writeText(myId); setCopied(true); setTimeout(() => setCopied(false), 1500); };

  /* lobby = invite friends, set rules, then start */
  if (tourney && tourney.status === "lobby") {
    const invitedIds = tourney.players.map((p) => p.id);
    const r = tourney.rules || DEFAULT_RULES;
    const isHost = tourney.hostId === myId;
    return (
      <Scroll>
        <SectionTitle icon={Trophy}>Tournament Lobby</SectionTitle>
        <div style={styles.codePill}>
          <span>INVITE CODE</span><b>{tourney.code}</b>
          <button style={styles.copyMini} onClick={() => navigator.clipboard?.writeText(tourney.code)}><Copy size={12} /></button>
        </div>

        <div style={styles.segment}>
          <button style={{ ...styles.segBtn, ...(ltab === "lobby" ? styles.segOn : {}) }} onClick={() => setLtab("lobby")}>Lobby</button>
          <button style={{ ...styles.segBtn, ...(ltab === "rules" ? styles.segOn : {}) }} onClick={() => setLtab("rules")}>Rules</button>
        </div>

        {ltab === "rules" ? (
          <>
            <p style={styles.muted}>{isHost ? "Choose how catches are scored in this tournament." : "Only the host can change the rules. Here's how this tournament is scored:"}</p>
            <div style={styles.setRow}>
              <DollarSign size={18} color={BLUE} /><span style={styles.setRowLabel}>Count weight (×10 pts/lb)</span>
              {isHost ? <Toggle on={r.weight} onClick={() => setRule("weight", !r.weight)} />
                : <span style={styles.setStatus}>{r.weight ? "On" : "Off"}</span>}
            </div>
            <div style={styles.setRow}>
              <Navigation size={18} color={BLUE} /><span style={styles.setRowLabel}>Count length (×1 pt/in)</span>
              {isHost ? <Toggle on={r.length} onClick={() => setRule("length", !r.length)} />
                : <span style={styles.setStatus}>{r.length ? "On" : "Off"}</span>}
            </div>
            <div style={styles.setRow}>
              <Fish size={18} color={BLUE} /><span style={styles.setRowLabel}>Points per catch</span>
              {isHost ? (
                <div style={styles.stepper}>
                  <button style={styles.stepBtn} onClick={() => setRule("perCatch", Math.max(0, (r.perCatch ?? 5) - 1))}>–</button>
                  <span style={{ minWidth: 22, textAlign: "center", fontWeight: 800, color: ICE }}>{r.perCatch ?? 5}</span>
                  <button style={styles.stepBtn} onClick={() => setRule("perCatch", (r.perCatch ?? 5) + 1)}>+</button>
                </div>
              ) : <span style={styles.setStatus}>{r.perCatch ?? 5}</span>}
            </div>
            {!isHost && <p style={styles.tinyMuted}>You joined this tournament, so the host controls the scoring rules.</p>}
            <div style={styles.infoCard}>
              <div style={styles.formula}>
                POINTS = {r.weight ? "(weight × 10)" : ""}{r.weight && r.length ? " + " : ""}{r.length ? "(length × 1)" : ""}
                {(r.weight || r.length) ? " + " : ""}(catches × {r.perCatch ?? 5})
              </div>
            </div>
          </>
        ) : (
          <>
            <p style={styles.muted}>Share the code or invite friends, then start the tournament.</p>
            <div style={styles.setGroupLabel}>IN THE LOBBY ({tourney.players.length})</div>
            {tourney.players.map((p) => (
              <div key={p.id} style={styles.friendRow}>
                <div style={styles.avatar}>{(p.you ? "Y" : p.name[0])}</div>
                <div style={{ flex: 1 }}><b>{p.you ? "You" : p.name}</b><div style={styles.lbSub}>{p.id}</div></div>
                <Check size={16} color={BLUE} />
              </div>
            ))}
            {friends.filter((f) => !invitedIds.includes(f.id)).length > 0 && (
              <>
                <div style={styles.setGroupLabel}>INVITE FRIENDS</div>
                {friends.filter((f) => !invitedIds.includes(f.id)).map((f) => (
                  <div key={f.id} style={styles.friendRow}>
                    <div style={styles.avatar}>{f.name[0]}</div>
                    <div style={{ flex: 1 }}><b>{f.name}</b><div style={styles.lbSub}>{f.id}</div></div>
                    <button style={styles.miniBtn} onClick={() => inviteToTourney(f)}>Invite</button>
                  </div>
                ))}
              </>
            )}
          </>
        )}

        <button style={styles.primaryBtn} onClick={beginTourney}><Trophy size={16} /> Start Tournament</button>
        <button style={{ ...styles.ghostBtn, color: "#ff7a7a", borderColor: "#ff7a7a44" }} onClick={cancelTourney}>Cancel</button>
      </Scroll>
    );
  }

  return (
    <Scroll>
      <div style={styles.segment}>
        <button style={{ ...styles.segBtn, ...(view === "friends" ? styles.segOn : {}) }} onClick={() => { setView("friends"); setOpenConv(null); }}>Friends</button>
        <button style={{ ...styles.segBtn, ...(view === "chats" ? styles.segOn : {}) }} onClick={() => setView("chats")}>
          Chats{conversations.length ? ` (${conversations.length})` : ""}
        </button>
      </div>

      {view === "friends" && (
        <>
          <div style={styles.idCard}>
            <div>
              <div style={styles.tinyMuted}>YOUR USER ID</div>
              <div style={{ fontSize: 26, fontWeight: 800, color: ICE }}>{myId}</div>
            </div>
            <button style={styles.copyBtn} onClick={copyId}>{copied ? <Check size={16} /> : <Copy size={16} />}</button>
          </div>

          <div style={styles.addRow}>
            <input value={addId} onChange={(e) => setAddId(e.target.value)} placeholder="Add friend by ID" style={styles.input} />
            <button style={styles.addBtn} onClick={addFriend}><Plus size={18} /></button>
          </div>

          {friends.length === 0 ? (
            <Empty text="No friends yet. Add someone by their user ID to get started." />
          ) : friends.map((f) => (
            <div key={f.id} style={styles.friendRow}>
              <div style={styles.avatar}>{f.name[0]}</div>
              <div style={{ flex: 1 }}><b>{f.name}</b><div style={styles.lbSub}>{f.id}</div></div>
              <div style={styles.onlineDot} />
            </div>
          ))}

          {tourney && tourney.status === "running" ? (
            <button style={{ ...styles.lakeRow, width: "100%", borderColor: BLUE, background: "#0c2748", marginTop: 16 }} onClick={goHome}>
              <Trophy size={18} color={ICE} />
              <div style={{ flex: 1, textAlign: "left" }}>
                <div style={{ fontWeight: 700, color: ICE }}>Tournament in progress</div>
                <div style={styles.lbSub}>Log catches and end it on the Home tab</div>
              </div>
              <ChevronRight size={16} color={ICE} />
            </button>
          ) : (
            <div style={{ display: "flex", gap: 10, marginTop: 16 }}>
              <button style={{ ...styles.primaryBtn, flex: 1 }} onClick={startTourney}><Trophy size={16} /> Start tournament</button>
              <button style={{ ...styles.ghostBtn, flex: 1, marginTop: 0 }} onClick={() => setJoinOpen(true)}>Join tournament</button>
            </div>
          )}
        </>
      )}

      {view === "chats" && !current && (
        <>
          {conversations.length === 0 ? (
            <Empty text="No active conversations yet." />
          ) : conversations.map((c) => {
            const last = c.messages[c.messages.length - 1];
            const unread = last.from === "seller";
            return (
              <button key={c.id} style={styles.convRow} onClick={() => setOpenConv(c.id)}>
                <div style={styles.avatar}>{c.seller[0]}</div>
                <div style={{ flex: 1, textAlign: "left", overflow: "hidden" }}>
                  <div style={{ fontWeight: 700 }}>{c.seller}</div>
                  <div style={styles.convPreview}>{last.from === "you" ? "You: " : ""}{last.text}</div>
                  <div style={styles.tinyMuted2}>{c.title}</div>
                </div>
                {unread && <div style={styles.unreadDot} />}
              </button>
            );
          })}
        </>
      )}

      {view === "chats" && current && (
        <>
          <button style={styles.backBtn} onClick={() => setOpenConv(null)}><ArrowLeft size={16} /> All chats</button>
          <div style={styles.convItemHead}>
            <div style={{ fontWeight: 700 }}>{current.title}</div>
            <div style={styles.lbSub}>${current.price} · {current.cat}</div>
          </div>
          <Chat item={current} onSend={(t) => sendMsg(current.id, t)} />
        </>
      )}

      {joinOpen && (
        <div style={styles.modalWrap} onClick={() => setJoinOpen(false)}>
          <div style={styles.modal} onClick={(e) => e.stopPropagation()}>
            <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 12 }}>Enter tournament code</div>
            <input value={joinCode} onChange={(e) => setJoinCode(e.target.value)} placeholder="RLX-XXXX" style={styles.input} autoFocus />
            <button style={{ ...styles.primaryBtn, marginTop: 12 }} onClick={join}>Join</button>
            <button style={styles.ghostBtn} onClick={() => setJoinOpen(false)}>Cancel</button>
          </div>
        </div>
      )}
    </Scroll>
  );
}

/* ============================ CHAT (shared) ============================ */
function Chat({ item, onSend }) {
  const [text, setText] = useState("");
  const send = () => { if (!text.trim()) return; onSend(text.trim()); setText(""); };
  return (
    <div style={styles.chatBox}>
      <div style={styles.chatHead}><MessageCircle size={15} color={BLUE} /> {item.seller}</div>
      <div style={styles.chatThread}>
        {item.messages.map((m, i) => (
          <div key={i} style={{ ...styles.bubble, alignSelf: m.from === "you" ? "flex-end" : "flex-start",
            background: m.from === "you" ? BLUE : "#10202f", color: m.from === "you" ? "#05070d" : "#e8eef4" }}>
            {m.text}
          </div>
        ))}
      </div>
      <div style={styles.chatInputRow}>
        <input value={text} onChange={(e) => setText(e.target.value)} onKeyDown={(e) => e.key === "Enter" && send()}
          placeholder="Message…" style={{ ...styles.input, height: 42 }} />
        <button style={styles.sendBtn} onClick={send}><Send size={16} /></button>
      </div>
    </div>
  );
}

/* ============================ MARKETPLACE ============================ */
const OFFICIAL = [
  { key: "bobber", title: "ReelLogix Smart Bobber", price: 49, accent: "#7fd4ff",
    desc: "Bluetooth strike-detecting bobber. It senses bites, logs depth and water temperature, and auto-records your catch into a live tournament." },
  { key: "fillet", title: "ReelLogix Smart Fillet Board", price: 129, accent: "#a7d62a",
    desc: "Measuring board with a built-in scale. It captures length and weight, photographs the fish, and syncs straight to your tackle log." },
];

function Marketplace({ listings, setListings, username, sendMsg }) {
  const [q, setQ] = useState("");
  const [mtab, setMtab] = useState("community"); // community | official
  const [view, setView] = useState("list");      // list | detail | post
  const [openId, setOpenId] = useState(null);
  const [official, setOfficial] = useState(null);

  const list = listings.filter((i) => (i.title + i.cat + i.seller).toLowerCase().includes(q.toLowerCase()));
  const current = listings.find((l) => l.id === openId);
  const officialItem = OFFICIAL.find((o) => o.key === official);

  const addListing = (item) => {
    setListings((p) => [{ id: uid(), seller: username, messages: [], ...item }, ...p]);
    setView("list");
  };

  if (view === "post") return <PostItem onCancel={() => setView("list")} onSave={addListing} />;
  if (view === "detail" && current)
    return <Listing item={current} onBack={() => setView("list")} onSend={(t) => sendMsg(current.id, t)} />;
  if (officialItem) return <OfficialProduct item={officialItem} onBack={() => setOfficial(null)} />;

  return (
    <Scroll>
      <SectionTitle icon={Store}>Marketplace</SectionTitle>

      <div style={styles.segment}>
        <button style={{ ...styles.segBtn, ...(mtab === "community" ? styles.segOn : {}) }} onClick={() => setMtab("community")}>Community</button>
        <button style={{ ...styles.segBtn, ...(mtab === "official" ? styles.segOn : {}) }} onClick={() => setMtab("official")}>Sold by ReelLogix</button>
      </div>

      {mtab === "community" && (
        <>
          <div style={styles.searchRow}>
            <Search size={16} color="#5b6675" />
            <input value={q} onChange={(e) => setQ(e.target.value)} placeholder="Search gear for sale…" style={styles.searchInput} />
          </div>
          <button style={styles.primaryBtn} onClick={() => setView("post")}><Plus size={16} /> Post an item for sale</button>
          <div style={styles.grid}>
            {list.map((i) => (
              <button key={i.id} style={{ ...styles.card, textAlign: "left", border: "1px solid #ffffff14" }}
                onClick={() => { setOpenId(i.id); setView("detail"); }}>
                <div style={{ ...styles.cardImg, background: i.image ? "#000" : `radial-gradient(circle at 50% 40%, ${i.accent}33, #0a1320)` }}>
                  {i.image ? <img src={i.image} alt={i.title} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
                    : <Tag size={28} color={i.accent} />}
                  <span style={styles.priceTag}>${i.price}</span>
                </div>
                <div style={{ padding: "8px 10px" }}>
                  <div style={{ fontWeight: 700, fontSize: 13, lineHeight: 1.2 }}>{i.title}</div>
                  <div style={styles.lbSub}>by {i.seller}</div>
                </div>
              </button>
            ))}
          </div>
          {list.length === 0 && <Empty text="Nothing matches your search yet." />}
        </>
      )}

      {mtab === "official" && (
        <div style={styles.grid}>
          {OFFICIAL.map((o) => (
            <button key={o.key} style={{ ...styles.card, textAlign: "left", border: "1px solid #1f8bff33" }} onClick={() => setOfficial(o.key)}>
              <div style={{ ...styles.cardImg, background: `radial-gradient(circle at 50% 40%, ${o.accent}33, #0a1320)` }}>
                <Blueprint kind={o.key} mini />
                <span style={{ ...styles.soonPill, position: "absolute", top: 8, left: 8 }}>Coming soon</span>
              </div>
              <div style={{ padding: "8px 10px" }}>
                <div style={{ fontWeight: 700, fontSize: 13, lineHeight: 1.2 }}>{o.title}</div>
                <div style={{ color: ICE, fontWeight: 800, marginTop: 2 }}>${o.price}</div>
              </div>
            </button>
          ))}
        </div>
      )}
    </Scroll>
  );
}

