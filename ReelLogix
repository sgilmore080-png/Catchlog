        <p style={styles.factual}>Data provided by the National Weather Service (NWS). This app is not affiliated with or endorsed by NOAA/NWS. Weather is factual information, not a recommendation.</p>
      )}
      {wx && wx.error && <div style={styles.aiErr}>{wx.error}</div>}

      {catchOpen && <CatchForm rules={rules} onClose={() => setCatchOpen(false)} onSave={addCatch} />}
    </Scroll>
  );
