const LAKES = [
  { name: "Lake of the Ozarks", lat: 38.146, lng: -92.756, d: "Largemouth & crappie" },
  { name: "Mark Twain Lake", lat: 39.535, lng: -91.636, d: "Bass & catfish" },
  { name: "Table Rock Lake", lat: 36.595, lng: -93.31, d: "Smallmouth haven" },
];
/* loads Leaflet from CDN on demand so a real map works in any browser */
function ensureLeaflet() {
  return new Promise((resolve) => {
    if (typeof window === "undefined") return resolve(null);
    if (window.L) return resolve(window.L);
    if (!document.getElementById("leaflet-css")) {
      const link = document.createElement("link");
      link.id = "leaflet-css"; link.rel = "stylesheet";
      link.href = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css";
      document.head.appendChild(link);
    }
    let s = document.getElementById("leaflet-js");
    if (s) { s.addEventListener("load", () => resolve(window.L)); return; }
    s = document.createElement("script");
    s.id = "leaflet-js";
    s.src = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js";
    s.onload = () => resolve(window.L);
    s.onerror = () => resolve(null);
    document.body.appendChild(s);
  });
}

function MapTab({ synced, coords, locError, requestLocation, waypoints, setWaypoints }) {
  const [active, setActive] = useState(null);
  const [ready, setReady] = useState(false);
  const [saveOpen, setSaveOpen] = useState(false);
  const [wpName, setWpName] = useState("");
  const elRef = useRef(null);
  const mapRef = useRef(null);
  const meRef = useRef(null);
  const wpLayer = useRef(null);
  const haveFix = synced && coords;

  // init the map once the container exists
  useEffect(() => {
    let cancelled = false;
    ensureLeaflet().then((L) => {
      if (cancelled || !L || !elRef.current || mapRef.current) return;
      const start = coords ? [coords.lat, coords.lng] : [39.5, -98.35];
      const map = L.map(elRef.current, { zoomControl: true, attributionControl: true }).setView(start, coords ? 12 : 4);
      L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", {
        maxZoom: 19, attribution: "Imagery &copy; Esri, Maxar, Earthstar Geographics",
      }).addTo(map);
      mapRef.current = map;
      setReady(true);
    });
    return () => { cancelled = true; if (mapRef.current) { mapRef.current.remove(); mapRef.current = null; } };
  }, []);

  // "you are here" marker
  useEffect(() => {
    const L = window.L; const map = mapRef.current;
    if (!L || !map || !coords) return;
    map.setView([coords.lat, coords.lng], 13);
    if (meRef.current) { meRef.current.remove(); meRef.current = null; }
    const grp = L.layerGroup().addTo(map);
    if (coords.acc) L.circle([coords.lat, coords.lng], { radius: coords.acc, color: "#1f8bff", weight: 1, fillColor: "#1f8bff", fillOpacity: 0.12 }).addTo(grp);
    L.circleMarker([coords.lat, coords.lng], { radius: 8, color: "#7fd4ff", weight: 3, fillColor: "#1f8bff", fillOpacity: 0.95 }).addTo(grp);
    meRef.current = grp;
  }, [coords, ready]);

  // render saved waypoint pins
  useEffect(() => {
    const L = window.L; const map = mapRef.current;
    if (!L || !map) return;
    if (wpLayer.current) { wpLayer.current.remove(); wpLayer.current = null; }
    const grp = L.layerGroup().addTo(map);
    (waypoints || []).forEach((w) => {
      L.marker([w.lat, w.lng]).addTo(grp).bindPopup(w.name);
    });
    wpLayer.current = grp;
  }, [waypoints, ready]);

  const goTo = (lat, lng, name) => { setActive(name); if (mapRef.current) mapRef.current.flyTo([lat, lng], 13); };

  const saveWaypoint = () => {
    const name = wpName.trim() || `Spot ${(waypoints?.length || 0) + 1}`;
    const c = mapRef.current ? mapRef.current.getCenter() : (coords ? { lat: coords.lat, lng: coords.lng } : null);
    if (!c) return;
    setWaypoints((p) => [...(p || []), { id: uid(), name, lat: c.lat, lng: c.lng }]);
    setWpName(""); setSaveOpen(false);
  };

  return (
    <Scroll>
      <SectionTitle icon={Navigation}>Map</SectionTitle>
      <div style={styles.mapBox}>
        <AttributionBadge kind="maps" corner />
        <div ref={elRef} style={styles.leaflet} />
        {ready && <button style={styles.saveWpBtn} onClick={() => setSaveOpen(true)}><MapPin size={15} /> Save waypoint</button>}
        {!ready && <div style={styles.mapOverlay}><p style={{ color: "#b9c6d6", fontSize: 13 }}>Loading map…</p></div>}
        {ready && !synced && (
          <div style={styles.mapOverlay}>
            <MapPin size={26} color={ICE} />
            <p style={{ margin: "8px 0 12px", color: "#b9c6d6", fontSize: 13 }}>Allow location to center the map on your exact position</p>
            <button style={styles.primaryBtn} onClick={requestLocation}>Allow location</button>
          </div>
        )}
        {ready && synced && !coords && !locError && (
          <div style={styles.mapOverlay}><p style={{ color: "#b9c6d6", fontSize: 13 }}>Locating you…</p></div>
        )}
      </div>

      {locError && (
        <div style={styles.aiErr}>{locError}
          <button style={{ ...styles.miniBtn, marginTop: 8 }} onClick={requestLocation}>Try again</button>
        </div>
      )}

      {haveFix && (
        <div style={styles.coordCard}>
          <MapPin size={16} color={ICE} />
          <span>You're at <b style={{ color: ICE }}>{coords.lat.toFixed(5)}, {coords.lng.toFixed(5)}</b>{coords.acc ? ` · ±${Math.round(coords.acc)}m` : ""}</span>
        </div>
      )}

      {/* BOOKMARKED LOCATIONS */}
      <div style={styles.setGroupLabel}>BOOKMARKED LOCATIONS ({(waypoints || []).length})</div>
      {(waypoints || []).length === 0 ? (
        <Empty text="No saved spots yet. Pan the map to a fishing spot and tap Save waypoint." />
      ) : waypoints.map((w) => (
        <button key={w.id} onClick={() => goTo(w.lat, w.lng, w.name)}
          style={{ ...styles.lakeRow, borderColor: active === w.name ? BLUE : "#ffffff14", background: active === w.name ? "#0c2748" : "#0b1422" }}>
          <MapPin size={18} color={BLUE} />
          <div style={{ flex: 1, textAlign: "left" }}>
            <div style={{ fontWeight: 700 }}>{w.name}</div>
            <div style={styles.lbSub}>{w.lat.toFixed(4)}, {w.lng.toFixed(4)}</div>
          </div>
          <button style={styles.wpDel} onClick={(e) => { e.stopPropagation(); setWaypoints((p) => p.filter((x) => x.id !== w.id)); }}><X size={14} /></button>
        </button>
      ))}

      {haveFix && (
        <>
          <div style={styles.setGroupLabel}>NEARBY LAKES</div>
          {LAKES.map((l) => (
            <button key={l.name} onClick={() => goTo(l.lat, l.lng, l.name)}
              style={{ ...styles.lakeRow, borderColor: active === l.name ? BLUE : "#ffffff14", background: active === l.name ? "#0c2748" : "#0b1422" }}>
              <Waves size={18} color={BLUE} />
              <div style={{ flex: 1, textAlign: "left" }}>
                <div style={{ fontWeight: 700 }}>{l.name}</div>
                <div style={styles.lbSub}>{l.d}</div>
              </div>
              {active === l.name && <Check size={16} color={ICE} />}
            </button>
          ))}
        </>
      )}

      {saveOpen && (
        <div style={styles.modalWrap} onClick={() => setSaveOpen(false)}>
          <div style={styles.modal} onClick={(e) => e.stopPropagation()}>
            <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 4 }}>Save this spot</div>
            <p style={styles.tinyMuted}>Saves the center of the map view.</p>
            <input value={wpName} onChange={(e) => setWpName(e.target.value)} placeholder="Name (e.g. North cove, dock pilings)" style={styles.input} autoFocus />
            <button style={{ ...styles.primaryBtn, marginTop: 12 }} onClick={saveWaypoint}>Save waypoint</button>
            <button style={styles.ghostBtn} onClick={() => setSaveOpen(false)}>Cancel</button>
          </div>
        </div>
      )}
    </Scroll>
  );
}

