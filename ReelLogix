  inshore: [["Spoon", "Weedless gold spoon"], ["Soft Plastics", "Paddle-tail, shrimp imitation"], ["Topwater", "Walking bait"], ["Jig", "Shrimp jig under a cork"]],
  carp: [["Bait", "Dough bait, sweet corn"], ["Bait", "Boilies, pack bait"]],
  default: [["Jig", "All-purpose jig"], ["Soft Plastics", "Grub or worm"], ["Crankbait", "Mid-depth diver"], ["Live Bait", "Worm or minnow"]],
};
const KW = [
  [/striped bass|white bass|hybrid|wiper|yellow bass/, "tempbass"],
  [/bass/, "blackbass"],
  [/trout|salmon|char\b|grayling|steelhead/, "trout"],
  [/pike|muskie|musky|muskellunge|pickerel/, "pike"],
  [/walleye|sauger/, "walleye"],
  [/catfish|bullhead|madtom/, "catfish"],
  [/crappie|sunfish|bluegill|perch|pumpkinseed|warmouth|redear/, "panfish"],
  [/redfish|red drum|drum|snook|seatrout|sea trout|flounder|sheepshead|snapper|grouper/, "inshore"],
  [/carp|buffalo/, "carp"],
];
function luresFor(name) {
  const f = FISH.find((x) => x.name.toLowerCase() === (name || "").toLowerCase());
  if (f) return { lures: f.lures, note: f.note };
  const n = (name || "").toLowerCase();
  for (const [re, key] of KW) if (re.test(n)) return { lures: GENERIC[key], note: "" };
  return { lures: GENERIC.default, note: "" };
}
const titleCase = (s) => (s || "").replace(/\b\w/g, (c) => c.toUpperCase());
const stripHtml = (s) => (s || "").replace(/<[^>]+>/g, "").replace(/&[a-z]+;/g, " ").replace(/\s+/g, " ").trim();

function FishGuide({ coords, requestLocation }) {
  const [stateName, setStateName] = useState("your area");
  const [items, setItems] = useState(null);
  const [loading, setLoading] = useState(false);
  const [err, setErr] = useState("");
  const [open, setOpen] = useState(null);   // selected species {id,name,sci,photo,attr}
  const [desc, setDesc] = useState(null);

  useEffect(() => {
    if (!coords) return;
    let abort = false;
    setLoading(true); setErr(""); setItems(null);
    (async () => {
      try {
        try {
          const g = await fetch(`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${coords.lat}&longitude=${coords.lng}&localityLanguage=en`).then((r) => r.json());
          if (!abort) setStateName(g.principalSubdivision || g.locality || "your area");
        } catch (e) { /* keep default */ }
        const url = `https://api.inaturalist.org/v1/observations/species_counts?taxon_id=47178&lat=${coords.lat}&lng=${coords.lng}&radius=170&quality_grade=research&per_page=40&locale=en`;
        const data = await fetch(url).then((r) => r.json());
        if (abort) return;
        const list = (data.results || []).map((r) => ({
          id: r.taxon.id,
          name: r.taxon.preferred_common_name ? titleCase(r.taxon.preferred_common_name) : r.taxon.name,
          sci: r.taxon.name,
          photo: r.taxon.default_photo ? r.taxon.default_photo.medium_url : null,
          attr: r.taxon.default_photo ? r.taxon.default_photo.attribution : "",
          count: r.count,
        }));
        setItems(list);
      } catch (e) {
        if (!abort) setErr("Couldn't load fish for your area — showing the general guide.");
      } finally { if (!abort) setLoading(false); }
    })();
    return () => { abort = true; };
  }, [coords]);

  const openFish = async (f) => {
    setOpen(f); setDesc(null);
    try {
      const d = await fetch(`https://api.inaturalist.org/v1/taxa/${f.id}?locale=en`).then((r) => r.json());
      const t = d.results && d.results[0];
      setDesc(t && t.wikipedia_summary ? stripHtml(t.wikipedia_summary) : "");
    } catch (e) { setDesc(""); }
  };

  // ---- species detail ----
  if (open) {
    const { lures, note } = luresFor(open.name);
    return (
      <>
        <button style={styles.backBtn} onClick={() => setOpen(null)}><ArrowLeft size={16} /> Fish in {stateName}</button>
        <div style={styles.fishHero}>
          {open.photo ? <img src={open.photo} alt={open.name} style={{ width: "100%", maxHeight: 200, objectFit: "cover", borderRadius: 12 }} />
            : <FishArt size={150} />}
        </div>
        {open.attr && <div style={styles.photoAttr}>{stripHtml(open.attr)}</div>}
        <h2 style={{ fontFamily: "'Saira Condensed', sans-serif", fontWeight: 800, fontSize: 24, margin: "10px 0 0" }}>{open.name}</h2>
        <div style={{ ...styles.lbSub, fontStyle: "italic", marginBottom: 6 }}>{open.sci}</div>
        <p style={styles.muted}>{desc === null ? "Loading description…" : (desc || note || "A species found in your region.")}</p>
        <div style={styles.setGroupLabel}>LURES THAT CATCH IT</div>
        {lures.map(([cat, ex]) => (
          <div key={cat} style={styles.lureCat}>
            <div style={styles.lureCatHead}><span style={styles.catDot} />{cat}</div>
            <div style={styles.lbSub}>{ex}</div>
          </div>
        ))}
      </>
    );
  }

  // ---- no location yet ----
  if (!coords) {
    return (
      <div style={{ ...styles.infoCard, textAlign: "center" }}>
        <MapPin size={26} color={ICE} />
        <p style={{ ...styles.muted, marginTop: 8 }}>Turn on location to see the fish species found in your state.</p>
        <button style={styles.primaryBtn} onClick={requestLocation}>Use my location</button>
      </div>
    );
  }

  // ---- located: live list (with graceful fallback) ----
  const showFallback = !loading && (err || (items && items.length === 0));
  return (
    <>
      <div style={styles.setGroupLabel}>FISH IN {stateName.toUpperCase()}</div>
      {loading && <div style={styles.infoCard}><p style={{ ...styles.muted, margin: 0 }}>Finding fish near you…</p></div>}
      {err && <div style={styles.aiErr}>{err}</div>}

      {!loading && !showFallback && items && items.map((f) => (
        <button key={f.id} style={styles.fishRow} onClick={() => openFish(f)}>
          <div style={styles.fishThumb}>
            {f.photo ? <img src={f.photo} alt={f.name} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
              : <FishArt size={58} />}
          </div>
          <div style={{ flex: 1, textAlign: "left", overflow: "hidden" }}>
            <div style={{ fontWeight: 700 }}>{f.name}</div>
            <div style={{ ...styles.lbSub, fontStyle: "italic" }}>{f.sci}</div>
          </div>
          <ChevronRight size={16} color="#5b6675" />
        </button>
      ))}

      {showFallback && FISH.map((f) => (
        <button key={f.name} style={styles.fishRow} onClick={() => openFish({ id: 0, name: f.name, sci: "", photo: null, attr: "" })}>
          <div style={styles.fishThumb}><FishArt body={f.body} belly={f.belly} fin={f.fin} pattern={f.pattern} size={58} /></div>
          <div style={{ flex: 1, textAlign: "left" }}>
            <div style={{ fontWeight: 700 }}>{f.name}</div>
            <div style={styles.lbSub}>{f.lures.length} lure types · tap to view</div>
          </div>
          <ChevronRight size={16} color="#5b6675" />
        </button>
      ))}
    </>
  );
}

