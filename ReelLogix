          {tab === "map" && <MapTab synced={synced} coords={coords} locError={locError} requestLocation={requestLocation} waypoints={waypoints} setWaypoints={setWaypoints} />}
          {tab === "tackle" && <Tackle lures={lures} setLures={setLures} coords={coords} requestLocation={requestLocation} />}
          {tab === "friends" && (
