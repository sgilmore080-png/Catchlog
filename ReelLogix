function PostItem({ onCancel, onSave }) {
  const [title, setTitle] = useState("");
  const [price, setPrice] = useState("");
  const [cat, setCat] = useState("Reels");
  const [desc, setDesc] = useState("");
  const [image, setImage] = useState(null);
  const fileRef = useRef(null);
  const pick = (e) => {
    const f = e.target.files?.[0]; if (!f) return;
    const r = new FileReader(); r.onload = () => setImage(r.result); r.readAsDataURL(f);
  };
  const save = () => {
    if (!title.trim() || !price) return;
    onSave({ title: title.trim(), price: Number(price), cat, desc: desc.trim(), image, accent: "#7fd4ff" });
  };
  return (
    <Scroll>
      <button style={styles.backBtn} onClick={onCancel}><ArrowLeft size={16} /> Back</button>
      <SectionTitle icon={Tag}>Post an item</SectionTitle>

      <button style={styles.photoUpload} onClick={() => fileRef.current?.click()}>
        {image ? <img src={image} alt="" style={{ width: "100%", height: "100%", objectFit: "cover", borderRadius: 12 }} />
          : <><Camera size={22} color={ICE} /><span style={{ color: "#9aa7b6", fontSize: 12, marginTop: 6 }}>Add a photo</span></>}
      </button>
      <input ref={fileRef} type="file" accept="image/*" capture="environment" onChange={pick} style={{ display: "none" }} />

      <input value={title} onChange={(e) => setTitle(e.target.value)} placeholder="Item title (e.g. Shimano reel)" style={{ ...styles.input, marginBottom: 10 }} />
      <div style={{ display: "flex", gap: 10, marginBottom: 10 }}>
        <div style={{ ...styles.input, display: "flex", alignItems: "center", flex: 1 }}>
          <DollarSign size={15} color="#5b6675" />
          <input value={price} onChange={(e) => setPrice(e.target.value.replace(/[^\d]/g, ""))} placeholder="Price" inputMode="numeric"
            style={{ background: "none", border: "none", color: "#e8eef4", outline: "none", width: "100%", marginLeft: 4 }} />
        </div>
