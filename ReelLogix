const DEFAULT_RULES = { weight: true, length: false, perCatch: 5 };
const cWeight = (p) => (p.log || []).reduce((s, c) => s + (c.weight || 0), 0);
const cLength = (p) => (p.log || []).reduce((s, c) => s + (c.length || 0), 0);
const cCount = (p) => (p.log || []).length;
const ptsOf = (p, rules = DEFAULT_RULES) =>
  Math.round((rules.weight ? cWeight(p) * 10 : 0) + (rules.length ? cLength(p) * 1 : 0) + cCount(p) * (rules.perCatch ?? 5));

