/* ============================ AI PANEL ============================ */
function AIPanel({ onClose, lures, cond, setCond, weather, synced, onSync, units, wx }) {
  const [rec, setRec] = useState(null);
  const liveCur = wx && wx.current;
  const effTemp = liveCur ? wx.current.temp : weather.temp;
  const effLabel = liveCur ? wx.current.short : weather.label;
  const effCond = liveCur ? condFrom(wx.current.short) : cond;
  const effIcon = liveCur ? condIcon(effCond, 18) : weather.icon;

  const recommend = () => {
    if (!synced) { setRec({ err: "Enable weather & location first so I can factor in conditions." }); return; }
    if (!lures.length) { setRec({ err: "Your tackle box is empty — scan or add a lure first." }); return; }
    const wline = `Right now it's ${effLabel.toLowerCase()} and about ${fmtTemp(effTemp, units)}.`;
    let pick, why;
    if (effCond === "Sunny") {
      pick = lures.find((l) => l.brightness === "bright") || lures[0];
      why = `The bright, reflective finish on the ${pick.name} will flash and bounce sunlight underwater — that glint triggers reaction strikes in clear, high-light water, giving you the best shot at a bite.`;
    } else if (effCond === "Overcast") {
      pick = lures.find((l) => l.brightness === "dark") || lures.find((l) => l.brightness === "natural") || lures[0];
      why = `With low light, a darker, high-contrast lure like the ${pick.name} throws a strong silhouette that fish can lock onto against the gray surface light.`;
    } else {
      pick = lures.find((l) => /jig|spinner|chatter|blade/i.test(l.shape)) || lures.find((l) => l.brightness === "bright") || lures[0];
      why = `Rain has stained the water and cut visibility, so the ${pick.name} kicks out extra vibration and flash to help fish home in on it through the murk.`;
    }
    setRec({ pick, wx: wline, why });
  };

  return (
    <div style={styles.modalWrap} onClick={onClose}>
      <div style={{ ...styles.modal, maxHeight: "82%", overflow: "auto" }} onClick={(e) => e.stopPropagation()}>
        <button style={styles.modalX} onClick={onClose}><X size={16} /></button>
        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10 }}>
          <Sparkles size={20} color={BLUE} /><b style={{ fontSize: 17 }}>Logix AI</b>
        </div>

        <div style={styles.weatherRow}>
          {effIcon}
          <span style={{ flex: 1 }}>{synced ? `${effLabel}${liveCur ? "" : ""} · ${fmtTemp(effTemp, units)}` : "Weather & location not synced"}</span>
          {synced ? <AttributionBadge kind="weather" /> : <button style={styles.miniBtn} onClick={onSync}>Sync</button>}
        </div>
        {synced && <p style={styles.factual}>{liveCur ? "Live NWS data — factual information, not a recommendation." : "Weather shown is factual data, not a recommendation."}</p>}
        {synced && !liveCur && (
          <div style={styles.condRow}>
            {["Sunny", "Overcast", "Rain"].map((c) => (
              <button key={c} onClick={() => setCond(c)}
                style={{ ...styles.condBtn, background: cond === c ? BLUE : "#0b1422", color: cond === c ? "#05070d" : "#8a97a8" }}>{c}</button>
            ))}
          </div>
        )}

        <button style={styles.primaryBtn} onClick={recommend}>Recommend a lure</button>

        {rec?.err && <div style={styles.aiErr}>{rec.err}</div>}
        {rec?.pick && (
          <div style={styles.recCard}>
            <div style={styles.aiWx}>{effIcon}<span>{rec.wx}</span></div>
            <div style={{ display: "flex", gap: 12, alignItems: "center", marginTop: 10 }}>
              <div style={styles.recImg}>
                {rec.pick.image ? <img src={rec.pick.image} style={{ width: "100%", height: "100%", objectFit: "cover", borderRadius: 10 }} />
                  : <LureArt body={rec.pick.body} accent={rec.pick.accent} size={56} />}
              </div>
              <div><div style={{ fontWeight: 800, color: ICE }}>{rec.pick.name}</div><div style={styles.lbSub}>{rec.pick.color} · {rec.pick.shape}</div></div>
            </div>
            <p style={{ ...styles.muted, marginBottom: 0, marginTop: 10 }}>{rec.why}</p>
          </div>
        )}
      </div>
    </div>
  );
}

