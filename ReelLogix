            username={username} units={units} setUnits={setUnits}
            notifications={notifications} setNotifications={setNotifications}
            synced={synced} requestLocation={requestLocation}
            onEditProfile={() => { setSettingsOpen(false); setProfileOpen(true); }}
            onLogout={() => { setSettingsOpen(false); setSignedIn(false); }} />
        )}
      </div>
    </div>
  );
}

