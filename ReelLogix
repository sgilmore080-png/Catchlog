function FishArt({ body = "#6f8aa8", belly = "#e6eef6", fin = "#3f5d7e", pattern = "plain", size = 88 }) {
  const gid = "fg" + body.replace("#", "");
  return (
    <svg viewBox="0 0 130 86" width={size} height={size * 0.62}>
      <defs>
        <linearGradient id={gid} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stopColor={body} />
          <stop offset="1" stopColor={belly} />
        </linearGradient>
      </defs>
      {/* tail */}
      <path d="M20 43 l-15 -16 q6 16 0 32 z" fill={fin} />
      {/* dorsal fin */}
      <path d="M52 22 q18 -12 38 -3 l-6 11 q-16 -4 -28 0 z" fill={fin} />
      {/* body */}
      <ellipse cx="68" cy="43" rx="50" ry="23" fill={`url(#${gid})`} stroke="#0a1320" strokeWidth="1.4" />
      {/* belly sheen */}
