function condFrom(text) {
  const t = (text || "").toLowerCase();
  if (/rain|shower|storm|thunder|drizzle|snow|sleet/.test(t)) return "Rain";
  if (/cloud|overcast|fog|haze/.test(t)) return "Overcast";
  return "Sunny";
}
function condIcon(c, size = 18) {
  if (c === "Rain") return <CloudRain size={size} />;
  if (c === "Overcast") return <Cloud size={size} />;
  return <Sun size={size} />;
}

function Home({ tourney, setTourney, synced, units, wx, username }) {
  const [catchOpen, setCatchOpen] = useState(false);
  const rules = (tourney && tourney.rules) || DEFAULT_RULES;
  const status = tourney && tourney.status;

  const ranked = useMemo(() => {
    if (!tourney) return [];
    return [...tourney.players].map((p) => ({ ...p, points: ptsOf(p, rules) })).sort((a, b) => b.points - a.points);
  }, [tourney, rules]);

  const addCatch = (c) => {
    setTourney((t) => ({ ...t, players: t.players.map((p) => p.you ? { ...p, log: [...(p.log || []), c] } : p) }));
    setCatchOpen(false);
  };
  const sendTourneyMsg = (text) =>
    setTourney((t) => ({ ...t, chat: [...(t.chat || []), { from: username || "You", text, ts: Date.now() }] }));

  // weather: prefer live NWS, fall back to simulated state
  const cur = wx && wx.current;
  const cond = cur ? condFrom(cur.short) : "Sunny";

  return (
    <Scroll>
      {status === "ended" ? (
        <Results tourney={tourney} rules={rules} onDone={() => setTourney(null)} />
      ) : (
        <>
          <SectionTitle icon={Trophy}>Tournament Stat Log</SectionTitle>
          {!tourney ? (
            <Empty text="No live tournament. Head to the Friends tab to start or join one." />
          ) : (
            <>
              <div style={styles.codePill}><span>CODE</span><b>{tourney.code}</b>
                <span style={{ ...styles.statusPill, marginLeft: "auto" }}>{status === "running" ? "LIVE" : "LOBBY"}</span>
              </div>
              {status !== "running" && <p style={styles.muted}>Waiting to start — invite friends and tap Start Tournament on the Friends tab.</p>}
              {ranked.map((p, i) => (
                <div key={p.id} style={{ ...styles.lbRow, borderColor: i === 0 ? BLUE : "#ffffff14" }}>
                  <div style={styles.lbRank}>{i === 0 ? <Crown size={16} color="#ffd35b" /> : i + 1}</div>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontWeight: 700, color: p.you ? ICE : "#e8eef4" }}>{p.name}{p.you ? " (you)" : ""}</div>
                    <div style={styles.lbSub}>
                      {cCount(p)} catches{rules.weight ? ` · ${cWeight(p).toFixed(2)} lb` : ""}{rules.length ? ` · ${cLength(p).toFixed(1)} in` : ""}
                    </div>
                  </div>
                  <div style={styles.lbPts}>{p.points}<span>pts</span></div>
                </div>
              ))}
              {status === "running" && <button style={styles.primaryBtn} onClick={() => setCatchOpen(true)}>+ Log a catch</button>}
              <button style={{ ...styles.ghostBtn, color: "#ff7a7a", borderColor: "#ff7a7a44" }}
                onClick={() => setTourney((t) => ({ ...t, status: "ended" }))}>End tournament</button>

              <TournamentChat chat={tourney.chat || []} onSend={sendTourneyMsg} username={username} count={tourney.players.length} />
            </>
          )}
        </>
      )}

      {/* WEATHER */}
      <div style={styles.weatherCard}>
        {(cur || synced) && <AttributionBadge kind="weather" corner />}
        <div style={styles.weatherIcon}>{cur ? condIcon(cond, 18) : <Cloud size={18} />}</div>
        <div style={{ flex: 1 }}>
          <div style={styles.tinyMuted}>CURRENT CONDITIONS{wx && wx.place ? ` · ${wx.place}` : ""}</div>
          {cur ? (
            <>
              <div style={{ fontFamily: "'Saira Condensed', sans-serif", fontWeight: 900, fontSize: 26, lineHeight: 1, color: ICE }}>{fmtTemp(cur.temp, units)}</div>
              <div style={styles.lbSub}>{cur.short}</div>
            </>
          ) : wx && wx.loading ? (
            <div style={styles.lbSub}>Loading forecast…</div>
          ) : (
            <div style={styles.lbSub}>Enable location (Map or Settings) to load weather</div>
          )}
        </div>
      </div>

      {/* 5-day forecast */}
      {wx && wx.days && wx.days.length > 0 && (
        <div style={styles.forecastRow}>
          {wx.days.slice(0, 5).map((d) => (
            <div key={d.name} style={styles.fcCard}>
              <div style={styles.fcDay}>{d.name.slice(0, 3)}</div>
              <div style={{ color: ICE, margin: "4px 0" }}>{condIcon(condFrom(d.short), 18)}</div>
              <div style={styles.fcHi}>{fmtTemp(d.hi, units).replace("°F", "°").replace("°C", "°")}</div>
              {d.lo != null && <div style={styles.fcLo}>{fmtTemp(d.lo, units).replace("°F", "°").replace("°C", "°")}</div>}
