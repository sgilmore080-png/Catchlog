/* ---------- National Weather Service forecast (api.weather.gov) ----------
   NWS requires a User-Agent identifying the app + contact. Browsers treat
   User-Agent as a forbidden header and send their own, which NWS accepts; to
   guarantee a custom UA, proxy these calls through a server (see api/weather.js).
   We still set it for intent, add Accept, throttle, and handle 429/503. */
const NWS_UA = "(ReelLogix, contact@example.com)";
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
async function nwsFetch(url, tries = 3) {
  for (let i = 0; i < tries; i++) {
    const res = await fetch(url, { headers: { "User-Agent": NWS_UA, "Accept": "application/geo+json" } });
    if (res.ok) return res.json();
    if (res.status === 429 || res.status === 503) { await sleep(1500 * (i + 1)); continue; }
    throw new Error("NWS HTTP " + res.status);
  }
  throw new Error("NWS unavailable (throttled)");
}
async function getForecast(lat, lng) {
  // Prefer a serverless proxy (api/weather.js) which can set a real User-Agent
  // server-side. If it isn't deployed, fall back to direct browser calls.
  try {
    const r = await fetch(`/api/weather?lat=${lat.toFixed(4)}&lng=${lng.toFixed(4)}`);
    if (r.ok) { const j = await r.json(); if (j && j.current) return j; }
  } catch (e) { /* no proxy — fall through */ }

  const pts = await nwsFetch(`https://api.weather.gov/points/${lat.toFixed(4)},${lng.toFixed(4)}`);
  const fcUrl = pts.properties.forecast;
  const rl = pts.properties.relativeLocation && pts.properties.relativeLocation.properties;
  const place = rl ? `${rl.city}, ${rl.state}` : "";
  await sleep(1000); // be polite between sequential NWS requests
  const fc = await nwsFetch(fcUrl);
  const periods = (fc.properties && fc.properties.periods) || [];
  const current = periods[0] ? { temp: periods[0].temperature, short: periods[0].shortForecast } : null;
  const days = [];
  for (let i = 0; i < periods.length && days.length < 5; i++) {
    const p = periods[i];
    if (p.isDaytime) {
      const night = periods[i + 1] && !periods[i + 1].isDaytime ? periods[i + 1] : null;
      days.push({ name: p.name, hi: p.temperature, lo: night ? night.temperature : null, short: p.shortForecast });
    }
  }
  if (periods[0] && !periods[0].isDaytime && days.length < 5)
    days.unshift({ name: periods[0].name, hi: periods[0].temperature, lo: null, short: periods[0].shortForecast });
  return { place, current, days };
}

